# ArrCal — Radarr + Sonarr Calendar Dashboard
# Copy to .env and adjust values
#
# ── App Environment ──────────────────────────────────────────
# APP_ENV=local          # local | production
                          # local: dev-reload endpoint enabled

# ── Radarr Connection ───────────────────────────────────────
# RADARR_URL=http://localhost:7878
# RADARR_API_KEY=your-radarr-api-key
# RADARR_LABEL=              # optional display label (e.g. "HD Movies")

# ── Sonarr Connection ───────────────────────────────────────
# SONARR_URL=http://localhost:8989
# SONARR_API_KEY=your-sonarr-api-key
# SONARR_LABEL=              # optional display label (e.g. "Main TV")

# ── Cache ───────────────────────────────────────────────────
# CACHE_TTL=300           # cache time-to-live in seconds (default: 300 = 5 min)

# ── Rate Limiting ───────────────────────────────────────────
# Token-bucket per IP. Burst of RATE_LIMIT requests, then
# sustained at RATE_LIMIT / RATE_LIMIT_WINDOW req/s.
# RATE_LIMIT=120         # max requests per window (default: 120)
# RATE_LIMIT_WINDOW=60   # window duration in seconds (default: 60)

# ── Trusted Proxy / Client IP Resolution ────────────────────
# TRUST_PROXY=auto
# PROXY_IP_HEADER=X-Forwarded-For

# ── Multi-Instance Radarr / Sonarr ───────────────────────────
# RADARR_URL + RADARR_API_KEY above always produce instance 1.
# For additional instances, use numbered variables starting at 2.
# Set RADARR__AUTH__APIKEY / SONARR__AUTH__APIKEY in
# docker-compose for stable keys that match these .env values.
#
# RADARR_2_URL=http://localhost:7879
# RADARR_2_API_KEY=your-radarr-4k-api-key
# RADARR_2_LABEL=4K Movies
#
# SONARR_2_URL=http://localhost:8990
# SONARR_2_API_KEY=your-sonarr-anime-api-key
# SONARR_2_LABEL=Anime TV
